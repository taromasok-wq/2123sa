local API_KEY = "AIzaSyCntT7fakpZSIxkLmcUspeYFnD9PvZTuK8"
local MODEL = "gemini-3-flash-preview"
local TTS_BASE_URL = "https://music.madefor.cc/tts?voice=en-US-Standard-D&speed=1.0&text="

local speaker = peripheral.find("speaker")
local dfpwm = require("cc.audio.dfpwm")

-- Таблица для транслита
local ru2en = {
    ['а']='a', ['б']='b', ['в']='v', ['г']='g', ['д']='d', ['е']='e', ['ё']='yo', ['ж']='zh',
    ['з']='z', ['и']='i', ['й']='j', ['к']='k', ['л']='l', ['м']='m', ['н']='n', ['о']='o',
    ['п']='p', ['р']='r', ['с']='s', ['т']='t', ['у']='u', ['ф']='f', ['х']='kh', ['ц']='ts',
    ['ч']='ch', ['ш']='sh', ['щ']='shch', ['ы']='y', ['э']='e', ['ю']='yu', ['я']='ya'
}

local function toTranslit(text)
    local res = ""
    local lower = text:lower()
    for i=1, #lower do
        local char = lower:sub(i,i)
        res = res .. (ru2en[char] or char)
    end
    return res
end

local function speak(message)
    local url = TTS_BASE_URL .. textutils.urlEncode(message)
    local response, err = http.get { url = url, binary = true }
    if response then
        local decoder = dfpwm.make_decoder()
        while true do
            local chunk = response.read(16 * 1024)
            if not chunk then break end
            while not speaker.playAudio(decoder(chunk)) do os.pullEvent("speaker_audio_empty") end
        end
        response.close()
    end
end

local function askG(prompt)
    local url = "https://generativelanguage.googleapis.com/v1beta/models/" .. MODEL .. ":generateContent?key=" .. API_KEY
    local body = {
        systemInstruction = {
            parts = {{ text = "You are G, a cold logic-based AI robot. Speak ONLY in English, using simple words. No Russian. Be brief, answer in 5-7 words maximum. No emotions, just facts." }}
        },
        contents = {{ role = "user", parts = {{ text = prompt }} }}
    }
    
    local response, err = http.post(url, textutils.serializeJSON(body), {["Content-Type"] = "application/json"})
    if not response then return "Network error." end
    
    local raw = response.readAll()
    response.close()
    
    local data = textutils.unserializeJSON(raw)
    
    if data and data.candidates and data.candidates[1] then
        local text = data.candidates[1].content.parts[1].text
        
        -- САМОЕ ВАЖНОЕ: Удаляем все, что не является латиницей (ASCII)
        -- Это превратит "Привет" в "" (пустоту), поэтому мы меняем инструкцию ИИ
        local cleanText = ""
        for i = 1, #text do
            local byte = string.byte(text, i)
            if byte < 128 then
                cleanText = cleanText .. string.char(byte)
            end
        end
        return cleanText
    else
        return "Processing error."
    end
end

