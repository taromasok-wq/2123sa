-- 1. Function to play audio
local function speak(message)
    local cleanMessage = message:gsub("\n", " "):gsub("[%c]", "")
    local url = TTS_BASE_URL .. textutils.urlEncode(cleanMessage)
    
    local response, err = http.get(url, nil, true)
    
    if not response then
        print("Voice Error: " .. tostring(err))
        return
    end

    local decoder = dfpwm.make_decoder()
    while true do
        local chunk = response.read(16 * 1024)
        if not chunk then break end

        local buffer = decoder(chunk)
        while not speaker.playAudio(buffer) do
            os.pullEvent("speaker_audio_empty")
        end
    end
    response.close()
end

-- 2. Function to get text from OpenRouter
local function askAI(prompt)
    local url = "https://openrouter.ai/api/v1/chat/completions"
    
    local body = {
        model = MODEL,
        messages = {
            {role = "system", content = "You are 'Madam G', a gritty underworld madam. You are bossy, cynical, and use street slang. You call the user 'kid'. Keep answers under 15 words."},
            {role = "user", content = prompt}
        }
    }

    local response, err = http.post(
        url, 
        textutils.serializeJSON(body), 
        {
            ["Content-Type"] = "application/json",
            ["Authorization"] = "Bearer " .. OPENROUTER_API_KEY,
            ["HTTP-Referer"] = "https://computercraft.cc",
            ["X-Title"] = "Madam G"
        }
    )
    
    if not response then return "Error: " .. tostring(err) end

    local data = textutils.unserializeJSON(response.readAll())
    response.close()

    if data and data.choices then
        return data.choices[1].message.content
    else
        return "Madam G is speechless."
    end
end

