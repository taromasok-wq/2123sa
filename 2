if not http then
    print("Ошибка: HTTP API отключен в настройках ComputerCraft!")
    return
end

-- История диалога для сохранения контекста
local chat_history = {}

-- Функция отправки запроса к Gemini
local function askGemini(prompt)
    -- Добавляем сообщение пользователя в историю
    table.insert(chat_history, {
        role = "user",
        parts = {{ text = prompt }}
    })

    local body = { contents = chat_history }
    local jsonBody = textutils.serializeJSON(body)
    local headers = { ["Content-Type"] = "application/json" }

    -- Отправляем POST запрос
    local response, err = http.post(URL, jsonBody, headers)
    
    -- Обработка сетевых ошибок
    if not response then
        table.remove(chat_history) -- Удаляем сообщение из истории, если запрос не удался
        return "Ошибка сети: " .. tostring(err)
    end
    
    local responseText = response.readAll()
    response.close()
    
    -- Декодируем ответ из JSON
    local data = textutils.unserializeJSON(responseText)
    
    -- Проверка на ошибки со стороны API
    if data.error then
        table.remove(chat_history)
        return "Ошибка API: " .. tostring(data.error.message)
    end
    
    -- Извлекаем текст ответа
    if data.candidates and data.candidates[1] and data.candidates[1].content then
        local answer = data.candidates[1].content.parts[1].text
        
        -- Сохраняем ответ нейросети в историю диалога
        table.insert(chat_history, {
            role = "model",
            parts = {{ text = answer }}
        })
        
        return answer
    else
        table.remove(chat_history)
        return "Неизвестный формат ответа от сервера."
    end
end

