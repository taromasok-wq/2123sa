-- Функция транслитерации (Русский -> Транслит)
local ru2en = {
    ['а']='a', ['б']='b', ['в']='v', ['г']='g', ['д']='d', ['е']='e', ['ё']='yo', ['ж']='zh',
    ['з']='z', ['и']='i', ['й']='j', ['к']='k', ['л']='l', ['м']='m', ['н']='n', ['о']='o',
    ['п']='p', ['р']='r', ['с']='s', ['т']='t', ['у']='u', ['ф']='f', ['х']='kh', ['ц']='ts',
    ['ч']='ch', ['ш']='sh', ['щ']='shch', ['ы']='y', ['э']='e', ['ю']='yu', ['я']='ya',
    ['А']='A', ['Б']='B', ['В']='V', ['Г']='G', ['Д']='D', ['Е']='E', ['Ё']='Yo', ['Ж']='Zh',
    ['З']='Z', ['И']='I', ['Й']='J', ['К']='K', ['Л']='L', ['М']='M', ['Н']='N', ['О']='O',
    ['П']='P', ['Р']='R', ['С']='S', ['Т']='T', ['У']='U', ['Ф']='F', ['Х']='Kh', ['Ц']='Ts',
    ['Ч']='Ch', ['Ш']='Sh', ['Щ']='Shch', ['Ы']='Y', ['Э']='E', ['Ю']='Yu', ['Я']='Ya',
}

local function toTranslit(text)
    local res = ""
    for i=1, #text do
        local char = text:sub(i,i)
        res = res .. (ru2en[char] or char)
    end
    return res
end

local function speak(message)
    local url = TTS_BASE_URL .. textutils.urlEncode(message)
    local response, err = http.get { url = url, binary = true }
    if response then
        local decoder = dfpwm.make_decoder()
        while true do
            local chunk = response.read(16 * 1024)
            if not chunk then break end
            while not speaker.playAudio(decoder(chunk)) do os.pullEvent("speaker_audio_empty") end
        end
        response.close()
    end
end

local function askGemini(prompt)
    local url = "https://generativelanguage.googleapis.com/v1beta/models/" .. MODEL .. ":generateContent?key=" .. API_KEY
    local body = {
        systemInstruction = {
            parts = {{ text = "You are a cold, robotic cyber-madam. You speak only in Russian transliteration (using English letters). You are cynical, bossy, and call the user 'klient'. Keep answers very short." }}
        },
        contents = {{ role = "user", parts = {{ text = prompt }} }}
    }
    local response = http.post(url, textutils.serializeJSON(body), {["Content-Type"] = "application/json"})
    local data = textutils.unserializeJSON(response.readAll())
    return data.candidates[1].content.parts[1].text
end

