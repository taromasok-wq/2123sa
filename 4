while true do
    -- User input
    term.setTextColor(colors.yellow)
    write("You: ")
    term.setTextColor(colors.white)
    
    local input = read()
    
    if input == "exit" then
        print("Shutting down...")
        break
    elseif input == "clear" then
        chat_history = {}
        term.setTextColor(colors.green)
        print("[Chat history cleared]\n")
        term.setTextColor(colors.white)
    elseif input ~= "" then
        term.setTextColor(colors.gray)
        print("Gemini is typing...")
        
        -- Get response
        local answer = askGemini(input)
        
        -- Print response
        term.setTextColor(colors.cyan)
        print("\nGemini: ")
        term.setTextColor(colors.white)
        print(answer)
        print(string.rep("-", 30))
    end
end
