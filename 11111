-- === CONFIGURATION ===
local MODEL = "openai" 

-- TTS Config 
local VOICE = "en-US-Standard-D" 
local TTS_BASE_URL = "https://music.madefor.cc/tts?voice=" .. VOICE .. "&text="

-- Peripherals
local speaker = peripheral.find("speaker")
local dfpwm = require("cc.audio.dfpwm")

if not speaker then 
    error("Don V needs a Speaker to talk!", 0) 
end

-- 1. Function to play audio
local function speak(message)
    -- Очищаем текст от символов, ломающих генератор голоса
    local cleanMessage = message:gsub("\n", " "):gsub("[%c]", "")
    local url = TTS_BASE_URL .. textutils.urlEncode(cleanMessage)
    
    local response, err = http.get { url = url, binary = true }
    
    if not response then
        local fallbackUrl = "https://music.madefor.cc/tts?text=" .. textutils.urlEncode(cleanMessage)
        response, err = http.get { url = fallbackUrl, binary = true }
    end

    if not response then
        print("Voice Warning: Audio generation failed for this text. Read it on screen.")
        return
    end

    local decoder = dfpwm.make_decoder()
    while true do
        local chunk = response.read(16 * 1024)
        if not chunk then break end

        local buffer = decoder(chunk)
        while not speaker.playAudio(buffer) do
            os.pullEvent("speaker_audio_empty")
        end
    end
    response.close()
end

-- 2. Function to get text using Simple GET URL
local function askAI(prompt)
    -- ОБНОВЛЕННЫЙ ХАРАКТЕР: Теневой Информатор (без лимита слов, умный и полезный)
    local systemInstruction = "You are 'Don V', a well-connected underworld information broker and mob boss. You are cynical and use street slang, calling the user 'kid' or 'rookie', but you are highly intelligent and provide detailed, accurate, and highly useful information to ANY question. Explain things clearly. Answer in English only."

    local url = "https://text.pollinations.ai/" .. MODEL .. "/" 
        .. textutils.urlEncode(prompt) 
        .. "?system=" .. textutils.urlEncode(systemInstruction)

    local response, err = http.get(url)
    
    if response then
        local text = response.readAll()
        response.close()
        return text
    else
        return "Connection error: " .. tostring(err)
    end
end

-- === MAIN INTERFACE ===
term.clear()
term.setCursorPos(1,1)

while true do
    term.setTextColor(colors.white)
    write("You: ")
    local input = read()
    
    if input == "exit" then break end

    -- Get Text
    term.setTextColor(colors.yellow)
    print("Don V is checking his sources...")
    local answer = askAI(input)
    
    -- Print Text (сделал цвет ответа серым, чтобы легко читался длинный текст)
    term.setTextColor(colors.lightGray)
    print("\nDon V: " .. answer .. "\n")
    
    -- Play Voice
    speak(answer)
    
    term.setTextColor(colors.white)
    print("--------------------------")
end
